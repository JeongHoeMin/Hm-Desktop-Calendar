<Window xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HmDesktopCalendar.Views.MainWindow" x:CompileBindings="False"
        Width="980" Height="680" MinWidth="700" MinHeight="480"
        WindowDecorations="None" ShowInTaskbar="False" CanResize="False"
        ShowActivated="False" Background="Transparent"
        TransparencyLevelHint="Transparent" WindowStartupLocation="Manual">
  <Grid>
    <Border Classes="calendar-shell" Margin="6" Padding="10">
      <Grid RowDefinitions="44,24,*">
        <Grid x:Name="HeaderBar" Grid.Row="0" ColumnDefinitions="44,58,*,58">
          <Button x:Name="MenuButton" Classes="icon ghost" Content="☰"/>
          <Button x:Name="PreviousButton" Classes="icon ghost" Grid.Column="1" Content="◀"/>
          <Grid Grid.Column="2">
            <TextBlock x:Name="MonthTitle" Classes="title" Text="{Binding DisplayMonth}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Border x:Name="MoveBar" IsVisible="False" Background="{DynamicResource SocarMoveBarBrush}"
                    BorderBrush="{DynamicResource SocarBorderStrongBrush}" BorderThickness="1"
                    CornerRadius="{DynamicResource SocarRadiusSmall}"
                    Padding="14,6" Margin="10,2" Cursor="SizeAll"
                    HorizontalAlignment="Stretch" PointerPressed="MoveBar_OnPointerPressed">
              <TextBlock x:Name="MoveBarText" Text="☰  드래그하여 위치 이동"
                         Foreground="{DynamicResource SocarTextInverseBrush}"
                         FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </Border>
          </Grid>
          <Button x:Name="NextButton" Classes="icon ghost" Grid.Column="3" Content="▶"/>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="7">
          <TextBlock Classes="weekday sunday" Text="일" HorizontalAlignment="Center"/>
          <TextBlock Classes="weekday" Text="월" HorizontalAlignment="Center"/>
          <TextBlock Classes="weekday" Text="화" HorizontalAlignment="Center"/>
          <TextBlock Classes="weekday" Text="수" HorizontalAlignment="Center"/>
          <TextBlock Classes="weekday" Text="목" HorizontalAlignment="Center"/>
          <TextBlock Classes="weekday" Text="금" HorizontalAlignment="Center"/>
          <TextBlock Classes="weekday saturday" Text="토" HorizontalAlignment="Center"/>
        </UniformGrid>

        <ItemsControl x:Name="CalendarItems" Grid.Row="2" ItemsSource="{Binding Days}"
                      SizeChanged="CalendarItems_OnSizeChanged">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><UniformGrid Columns="7" Rows="6"/></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate><DataTemplate>
            <Border Classes="date-cell" Tag="{Binding Date}" Margin="1" Padding="4,2"
                    Opacity="{Binding CellOpacity}" ClipToBounds="True"
                    AttachedToVisualTree="Day_OnAttachedToVisualTree"
                    DetachedFromVisualTree="Day_OnDetachedFromVisualTree">
              <Grid RowDefinitions="18,*">
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Text="{Binding DayText}" FontSize="14" FontWeight="SemiBold"
                             VerticalAlignment="Center"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                              HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding IncompleteText}" IsVisible="{Binding HasIncomplete}"
                               Classes="status-warning" FontSize="9.5" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding CompletedText}" IsVisible="{Binding HasCompleted}"
                               Classes="schedule-more" FontSize="9.5"/>
                  </StackPanel>
                </Grid>
                <StackPanel Grid.Row="1" Spacing="0">
                  <ItemsControl ItemsSource="{Binding VisibleTasks}">
                    <ItemsControl.ItemTemplate><DataTemplate>
                      <Grid Height="16" ColumnDefinitions="36,*" Opacity="{Binding Opacity}">
                        <TextBlock Text="{Binding TimeText}" FontSize="10" FontWeight="Bold"
                                   Classes="schedule-time" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="11"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                   TextDecorations="{Binding TitleDecorations}"
                                   VerticalAlignment="Center"/>
                      </Grid>
                    </DataTemplate></ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Height="16" Text="{Binding HiddenText}"
                             IsVisible="{Binding HasHiddenTasks}" FontSize="10"
                             Classes="schedule-more" FontWeight="SemiBold"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate></ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>

    <Grid x:Name="ResizeOverlay" IsVisible="False">
      <Border Tag="North" Height="8" VerticalAlignment="Top" Margin="16,0"
              Background="{DynamicResource SocarResizeHitBrush}" Cursor="SizeNorthSouth" PointerPressed="ResizeHandle_OnPointerPressed"/>
      <Border Tag="South" Height="8" VerticalAlignment="Bottom" Margin="16,0"
              Background="{DynamicResource SocarResizeHitBrush}" Cursor="SizeNorthSouth" PointerPressed="ResizeHandle_OnPointerPressed"/>
      <Border Tag="West" Width="8" HorizontalAlignment="Left" Margin="0,16"
              Background="{DynamicResource SocarResizeHitBrush}" Cursor="SizeWestEast" PointerPressed="ResizeHandle_OnPointerPressed"/>
      <Border Tag="East" Width="8" HorizontalAlignment="Right" Margin="0,16"
              Background="{DynamicResource SocarResizeHitBrush}" Cursor="SizeWestEast" PointerPressed="ResizeHandle_OnPointerPressed"/>
      <Border Tag="NorthWest" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Top"
              Background="{DynamicResource SocarResizeHandleBrush}" Cursor="TopLeftCorner" PointerPressed="ResizeHandle_OnPointerPressed"/>
      <Border Tag="NorthEast" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top"
              Background="{DynamicResource SocarResizeHandleBrush}" Cursor="TopRightCorner" PointerPressed="ResizeHandle_OnPointerPressed"/>
      <Border Tag="SouthWest" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Bottom"
              Background="{DynamicResource SocarResizeHandleBrush}" Cursor="BottomLeftCorner" PointerPressed="ResizeHandle_OnPointerPressed"/>
      <Border Tag="SouthEast" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Bottom"
              Background="{DynamicResource SocarResizeHandleBrush}" Cursor="BottomRightCorner" PointerPressed="ResizeHandle_OnPointerPressed"/>
    </Grid>
  </Grid>
</Window>
