<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HmDesktopCalendar.Views.SettingsWindow"
        x:CompileBindings="False"
        Classes="dialog"
        Width="560" Height="610" MinWidth="480" MinHeight="480"
        Title="설정" WindowStartupLocation="CenterScreen"
        Topmost="True">
  <Grid Margin="24" RowDefinitions="Auto,20,*">
    <StackPanel Spacing="4">
      <TextBlock Text="설정" Classes="title" />
      <TextBlock Text="HmDesktopCalendar의 동작과 표시 방식을 관리합니다. 변경 사항은 즉시 적용됩니다."
                 Classes="caption" TextWrapping="Wrap" />
    </StackPanel>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" Margin="0,0,8,0">
      <Border Classes="card" Padding="18">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Spacing="4">
            <TextBlock Text="앱 정보" FontWeight="SemiBold" />
            <TextBlock Text="현재 설치된 애플리케이션 버전" Classes="caption" />
          </StackPanel>
          <Border Grid.Column="1"
                  Background="{DynamicResource SocarPrimarySoftBrush}"
                  CornerRadius="8" Padding="12,6"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource SocarPrimaryPressedBrush}" />
          </Border>
        </Grid>
      </Border>

      <Border Classes="card" Padding="18">
        <Grid RowDefinitions="Auto,14,Auto,14,Auto">
          <StackPanel Spacing="4">
            <TextBlock Text="외형" FontWeight="SemiBold" />
            <TextBlock Text="달력 글자 크기와 배경 투명도를 조절합니다."
                       Classes="caption" TextWrapping="Wrap" />
          </StackPanel>
          <Grid Grid.Row="2" ColumnDefinitions="*,180">
            <StackPanel Spacing="3" VerticalAlignment="Center">
              <TextBlock Text="글자 크기" FontWeight="SemiBold" />
              <TextBlock Text="달력 헤더와 날짜 셀에 적용" Classes="caption" />
            </StackPanel>
            <ComboBox Grid.Column="1"
                      SelectedIndex="{Binding FontScaleIndex, Mode=TwoWay}">
              <ComboBoxItem Content="작게 (90%)" />
              <ComboBoxItem Content="보통 (100%)" />
              <ComboBoxItem Content="크게 (115%)" />
            </ComboBox>
          </Grid>
          <Grid Grid.Row="4" ColumnDefinitions="*,180">
            <StackPanel Spacing="3" VerticalAlignment="Center">
              <TextBlock Text="배경 불투명도" FontWeight="SemiBold" />
              <TextBlock Text="달력 프레임과 날짜 셀에만 적용" Classes="caption" />
            </StackPanel>
            <Grid Grid.Column="1" ColumnDefinitions="*,44">
              <Slider Minimum="0.5" Maximum="1" TickFrequency="0.05"
                      IsSnapToTickEnabled="True"
                      Value="{Binding BackgroundOpacity, Mode=TwoWay}"
                      VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding BackgroundOpacityText}"
                         HorizontalAlignment="Right" VerticalAlignment="Center"
                         FontWeight="SemiBold" />
            </Grid>
          </Grid>
        </Grid>
      </Border>

      <Border Classes="card" Padding="18">
        <Grid RowDefinitions="Auto,14,Auto,14,Auto">
          <StackPanel Spacing="4">
            <TextBlock Text="달력 표시" FontWeight="SemiBold" />
            <TextBlock Text="요일 순서와 주말 날짜 숫자 색을 설정합니다."
                       Classes="caption" TextWrapping="Wrap" />
          </StackPanel>
          <Grid Grid.Row="2" ColumnDefinitions="*,180">
            <StackPanel Spacing="3" VerticalAlignment="Center">
              <TextBlock Text="주 시작 요일" FontWeight="SemiBold" />
              <TextBlock Text="달력의 첫 번째 열에 표시할 요일" Classes="caption" />
            </StackPanel>
            <ComboBox Grid.Column="1"
                      SelectedIndex="{Binding WeekStartIndex, Mode=TwoWay}">
              <ComboBoxItem Content="일요일" />
              <ComboBoxItem Content="월요일" />
            </ComboBox>
          </Grid>
          <Grid Grid.Row="4" ColumnDefinitions="*,Auto">
            <StackPanel Spacing="3" VerticalAlignment="Center">
              <TextBlock Text="주말 날짜 색상" FontWeight="SemiBold" />
              <TextBlock Text="일요일은 빨강, 토요일은 파랑으로 표시" Classes="caption" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1"
                          IsChecked="{Binding ColorWeekends, Mode=TwoWay}"
                          OnContent="켜짐" OffContent="꺼짐"
                          VerticalAlignment="Center" />
          </Grid>
        </Grid>
      </Border>

      <Border Classes="card" Padding="18">
        <Grid RowDefinitions="Auto,14,Auto">
          <StackPanel Spacing="4">
            <TextBlock Text="달력 창 위치" FontWeight="SemiBold" />
            <TextBlock Text="달력의 위치와 크기를 처음 실행할 때의 기본값으로 되돌립니다."
                       Classes="caption" TextWrapping="Wrap" />
          </StackPanel>
          <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
            <TextBlock Text="{Binding StatusMessage}"
                       IsVisible="{Binding HasStatus}"
                       Classes="caption" TextWrapping="Wrap"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <Button Grid.Column="1" Content="위치 초기화" Classes="secondary"
                    Click="ResetWindowPosition_OnClick" />
          </Grid>
        </Grid>
      </Border>

      <Border Classes="card" Padding="18">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Spacing="4">
            <TextBlock Text="Windows 자동 시작" FontWeight="SemiBold" />
            <TextBlock Text="Windows에 로그인하면 달력을 자동으로 실행합니다."
                       Classes="caption" TextWrapping="Wrap" />
            <TextBlock Text="{Binding AutoStartError}"
                       IsVisible="{Binding HasAutoStartError}"
                       Classes="status-warning" TextWrapping="Wrap" />
          </StackPanel>
          <ToggleSwitch Grid.Column="1"
                        IsChecked="{Binding IsAutoStartEnabled, Mode=TwoWay}"
                        IsEnabled="{Binding IsAutoStartAvailable}"
                        OnContent="켜짐" OffContent="꺼짐"
                        VerticalAlignment="Center" />
        </Grid>
      </Border>
    </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
