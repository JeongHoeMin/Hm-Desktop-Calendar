<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HmDesktopCalendar.Views.EditWindow"
        x:CompileBindings="False"
        Classes="dialog"
        Width="820" Height="700" MinWidth="640" MinHeight="560"
        Title="일정 편집" WindowStartupLocation="CenterScreen"
        Topmost="True">
  <Grid Margin="24" RowDefinitions="Auto,16,*,Auto">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock Text="{Binding DateTitle}" Classes="title" />
        <TextBlock Text="일정을 선택해 수정하거나 새 일정을 추가하세요."
                   Classes="caption" />
      </StackPanel>
      <Button Grid.Column="1" Content="＋ 새 일정" Classes="secondary"
              Click="New_OnClick" />
    </Grid>

    <Grid Grid.Row="2" ColumnDefinitions="280,16,*">
      <Border Classes="card" Padding="16">
        <Grid RowDefinitions="Auto,12,*">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="일정 목록" FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Border Grid.Column="1" Background="{DynamicResource SocarSurfaceMutedBrush}"
                    CornerRadius="10" Padding="8,2">
              <TextBlock Text="{Binding Items.Count, StringFormat={}{0}개}"
                         Classes="caption" />
            </Border>
          </Grid>
          <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Items}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,8" Padding="12"
                          Background="{DynamicResource SocarSurfaceSubtleBrush}"
                          BorderBrush="{DynamicResource SocarBorderBrush}"
                          BorderThickness="1" CornerRadius="10">
                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="4,8,*">
                      <Border Background="{Binding Color}" CornerRadius="2"
                              Grid.RowSpan="3" />
                      <Grid Grid.Column="2" ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <Border IsVisible="{Binding IsAnniversary}"
                                  Background="#E8F1FF" CornerRadius="5" Padding="5,1">
                            <TextBlock Text="기념일" Foreground="#0041E6"
                                       FontSize="10" FontWeight="Bold" />
                          </Border>
                          <Border IsVisible="{Binding HasScheduleSeriesScope}"
                                  Background="#E9F8F0" CornerRadius="5" Padding="5,1">
                            <TextBlock Text="{Binding SeriesBadgeText}"
                                       Foreground="#17663A" FontSize="10"
                                       FontWeight="Bold" />
                          </Border>
                          <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding IsCompleted}"
                                  IsVisible="{Binding !IsAnniversary}"
                                  IsHitTestVisible="False" Focusable="False"
                                  ToolTip.Tip="완료 상태" />
                      </Grid>
                      <StackPanel Grid.Row="1" Grid.Column="2"
                                  Orientation="Horizontal" Spacing="8"
                                  Margin="0,6,0,0">
                        <TextBlock Text="{Binding StartTime}" Classes="caption" />
                        <TextBlock Text="{Binding Notes}" Classes="caption"
                                   MaxWidth="160" TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                      <StackPanel Grid.Row="2" Grid.Column="2"
                                  Orientation="Horizontal" Spacing="6"
                                  Margin="0,10,0,0">
                        <Button Content="수정" Classes="secondary"
                                MinHeight="32" Padding="12,0"
                                Click="Edit_OnClick" />
                        <Button Content="삭제" Classes="ghost"
                                MinHeight="32" Padding="12,0"
                                Click="Delete_OnClick" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border Grid.Column="2" Classes="card" Padding="20">
        <ScrollViewer x:Name="EditorFormScroll"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="16">
            <Border Padding="14" Background="{Binding Background.PreviewBackgroundBrush}"
                    BorderBrush="{DynamicResource SocarBorderBrush}"
                    BorderThickness="1" CornerRadius="10">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Spacing="2">
                    <TextBlock Text="날짜 셀 배경" FontWeight="SemiBold"
                               Foreground="{Binding Background.PreviewForegroundBrush}" />
                    <TextBlock Text="이 날짜의 배경은 로그인한 모든 환경에 동기화됩니다."
                               FontSize="11"
                               Foreground="{Binding Background.PreviewForegroundBrush}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="15" FontSize="20"
                             FontWeight="Bold"
                             Foreground="{Binding Background.PreviewForegroundBrush}" />
                </Grid>
                <WrapPanel Orientation="Horizontal">
                  <Button Tag="#FFF3BF" Background="#FFF3BF" Width="32" Height="32"
                          MinWidth="32" MinHeight="32" Padding="0" Margin="0,0,6,0"
                          ToolTip.Tip="레몬" Click="BackgroundPaletteColor_OnClick" />
                  <Button Tag="#FFD8A8" Background="#FFD8A8" Width="32" Height="32"
                          MinWidth="32" MinHeight="32" Padding="0" Margin="0,0,6,0"
                          ToolTip.Tip="살구" Click="BackgroundPaletteColor_OnClick" />
                  <Button Tag="#D3F9D8" Background="#D3F9D8" Width="32" Height="32"
                          MinWidth="32" MinHeight="32" Padding="0" Margin="0,0,6,0"
                          ToolTip.Tip="민트" Click="BackgroundPaletteColor_OnClick" />
                  <Button Tag="#D0EBFF" Background="#D0EBFF" Width="32" Height="32"
                          MinWidth="32" MinHeight="32" Padding="0" Margin="0,0,6,0"
                          ToolTip.Tip="스카이" Click="BackgroundPaletteColor_OnClick" />
                  <Button Tag="#E5DBFF" Background="#E5DBFF" Width="32" Height="32"
                          MinWidth="32" MinHeight="32" Padding="0" Margin="0,0,6,0"
                          ToolTip.Tip="라일락" Click="BackgroundPaletteColor_OnClick" />
                  <Button Tag="#343A40" Background="#343A40" Width="32" Height="32"
                          MinWidth="32" MinHeight="32" Padding="0"
                          ToolTip.Tip="차콜" Click="BackgroundPaletteColor_OnClick" />
                </WrapPanel>
                <StackPanel Spacing="6">
                  <TextBox Text="{Binding Background.Color, Mode=TwoWay,
                                          UpdateSourceTrigger=PropertyChanged}"
                           PlaceholderText="#RRGGBB" MaxLength="7" />
                  <StackPanel Orientation="Horizontal" Spacing="8"
                              HorizontalAlignment="Right">
                    <Button Content="초기화" Classes="ghost"
                            Click="BackgroundReset_OnClick" />
                    <Button Content="배경 적용" Classes="secondary"
                            IsEnabled="{Binding Background.CanSave}"
                            Click="BackgroundSave_OnClick" />
                  </StackPanel>
                </StackPanel>
                <TextBlock Text="{Binding Background.ValidationMessage}"
                           IsVisible="{Binding Background.HasValidationError}"
                           Classes="status-warning" />
              </StackPanel>
            </Border>

            <StackPanel Spacing="2">
              <TextBlock Text="{Binding Draft.FormTitle}" FontSize="18"
                         FontWeight="SemiBold" />
              <TextBlock Text="추가와 수정에 같은 입력 규칙을 사용합니다."
                         Classes="caption" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="제목" FontWeight="SemiBold" />
              <TextBox Text="{Binding Draft.Title, Mode=TwoWay,
                                      UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="일정 제목을 입력하세요" MaxLength="500" />
            </StackPanel>

            <CheckBox Content="기념일 · 매년 반복"
                      IsChecked="{Binding Draft.IsAnniversary, Mode=TwoWay}"
                      ToolTip.Tip="기념일은 완료 상태 없이 매년 같은 날짜에 표시됩니다." />

            <StackPanel Spacing="10" IsVisible="{Binding Draft.IsSchedule}">
              <TextBlock Text="일정 범위" FontWeight="SemiBold" />
              <WrapPanel Orientation="Horizontal">
                <RadioButton Content="하루" Tag="Single" GroupName="SeriesMode"
                             IsChecked="{Binding Draft.IsSingleMode, Mode=OneWay}"
                             Margin="0,0,16,0" Click="SeriesMode_OnClick" />
                <RadioButton Content="기간" Tag="Range" GroupName="SeriesMode"
                             IsChecked="{Binding Draft.IsRangeMode, Mode=OneWay}"
                             Margin="0,0,16,0" Click="SeriesMode_OnClick" />
                <RadioButton Content="반복" Tag="Recurring" GroupName="SeriesMode"
                             IsChecked="{Binding Draft.IsRecurringMode, Mode=OneWay}"
                             Click="SeriesMode_OnClick" />
              </WrapPanel>

              <Border Padding="10" Background="#F8F9FC"
                      BorderBrush="{DynamicResource SocarBorderBrush}"
                      BorderThickness="1" CornerRadius="8">
                <TextBlock Text="{Binding Draft.SeriesSummary}" Classes="caption"
                           TextWrapping="Wrap" />
              </Border>

              <StackPanel Spacing="10"
                          IsVisible="{Binding Draft.IsRangeMode}">
                <StackPanel Spacing="6">
                  <TextBlock Text="시작일" FontWeight="SemiBold" />
                  <TextBox Text="{Binding Draft.StartDateText}" IsReadOnly="True" />
                </StackPanel>
                <StackPanel Spacing="6">
                  <TextBlock Text="종료일" FontWeight="SemiBold" />
                  <DatePicker SelectedDate="{Binding Draft.EndDateValue,
                                      Mode=TwoWay}" HorizontalAlignment="Stretch" />
                </StackPanel>
              </StackPanel>

              <StackPanel Spacing="10" IsVisible="{Binding Draft.IsRecurringMode}">
                <Grid ColumnDefinitions="*,12,*">
                  <StackPanel Spacing="6">
                    <TextBlock Text="반복 빈도" FontWeight="SemiBold" />
                    <ComboBox SelectedIndex="{Binding Draft.RecurrenceFrequencyIndex,
                                              Mode=TwoWay}">
                      <ComboBoxItem Content="매일" />
                      <ComboBoxItem Content="매주" />
                      <ComboBoxItem Content="매월" />
                      <ComboBoxItem Content="매년" />
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Text="반복 간격" FontWeight="SemiBold" />
                    <NumericUpDown Value="{Binding Draft.RecurrenceInterval,
                                           Mode=TwoWay}" Minimum="1" Increment="1"
                                   FormatString="0" />
                  </StackPanel>
                </Grid>

                <StackPanel Spacing="6"
                            IsVisible="{Binding Draft.IsWeeklyRecurrence}">
                  <TextBlock Text="반복 요일" FontWeight="SemiBold" />
                  <WrapPanel Orientation="Horizontal">
                    <CheckBox Content="일" IsChecked="{Binding Draft.Sunday}"
                              Margin="0,0,10,0" />
                    <CheckBox Content="월" IsChecked="{Binding Draft.Monday}"
                              Margin="0,0,10,0" />
                    <CheckBox Content="화" IsChecked="{Binding Draft.Tuesday}"
                              Margin="0,0,10,0" />
                    <CheckBox Content="수" IsChecked="{Binding Draft.Wednesday}"
                              Margin="0,0,10,0" />
                    <CheckBox Content="목" IsChecked="{Binding Draft.Thursday}"
                              Margin="0,0,10,0" />
                    <CheckBox Content="금" IsChecked="{Binding Draft.Friday}"
                              Margin="0,0,10,0" />
                    <CheckBox Content="토" IsChecked="{Binding Draft.Saturday}" />
                  </WrapPanel>
                </StackPanel>

                <CheckBox Content="반복 종료일 사용"
                          IsChecked="{Binding Draft.HasRecurrenceUntil,
                                      Mode=TwoWay}" />
                <StackPanel Spacing="6"
                            IsVisible="{Binding Draft.HasRecurrenceUntil}">
                  <TextBlock Text="반복 종료일 (포함)" FontWeight="SemiBold" />
                  <DatePicker SelectedDate="{Binding Draft.RecurrenceUntilValue,
                                      Mode=TwoWay}" HorizontalAlignment="Stretch" />
                </StackPanel>
              </StackPanel>
            </StackPanel>

            <Border Padding="10" Background="#FFF4D6" CornerRadius="8"
                    IsVisible="{Binding Draft.ShowsSeriesScopeNotice}">
              <TextBlock Text="{Binding Draft.SeriesScopeText}" Foreground="#7A4A00"
                         FontWeight="SemiBold" TextWrapping="Wrap" />
            </Border>

            <TextBlock Text="기념일은 완료 상태 없이 매년 같은 날짜에 반복됩니다."
                       IsVisible="{Binding Draft.IsAnniversary}" Classes="caption"
                       TextWrapping="Wrap" />

            <StackPanel Spacing="8">
              <TextBlock Text="시간" FontWeight="SemiBold" />
              <TimePicker SelectedTime="{Binding Draft.TimeValue, Mode=TwoWay}"
                          ClockIdentifier="24HourClock" MinuteIncrement="1"
                          HorizontalAlignment="Stretch" />
              <WrapPanel Orientation="Horizontal">
                <Button Content="시간 없음" Tag="none" Classes="ghost"
                        Margin="0,0,6,6" MinHeight="32" Padding="10,0"
                        Click="PresetTime_OnClick" />
                <Button Content="지금" Tag="now" Classes="ghost"
                        Margin="0,0,6,6" MinHeight="32" Padding="10,0"
                        Click="PresetTime_OnClick" />
                <Button Content="오전 9시" Tag="09:00" Classes="ghost"
                        Margin="0,0,6,6" MinHeight="32" Padding="10,0"
                        Click="PresetTime_OnClick" />
                <Button Content="정오" Tag="12:00" Classes="ghost"
                        Margin="0,0,6,6" MinHeight="32" Padding="10,0"
                        Click="PresetTime_OnClick" />
                <Button Content="오후 6시" Tag="18:00" Classes="ghost"
                        Margin="0,0,6,6" MinHeight="32" Padding="10,0"
                        Click="PresetTime_OnClick" />
              </WrapPanel>
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="메모" FontWeight="SemiBold" />
              <TextBox Text="{Binding Draft.Notes, Mode=TwoWay,
                                      UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="일정에 필요한 내용을 기록하세요"
                       AcceptsReturn="True" TextWrapping="Wrap"
                       MinHeight="96" MaxLength="10000" />
            </StackPanel>

            <CheckBox Content="{Binding Draft.CompletionLabel}"
                      IsChecked="{Binding Draft.IsCompleted,
                      Mode=TwoWay}" IsVisible="{Binding Draft.IsSchedule}" />

            <StackPanel Spacing="8">
              <TextBlock Text="텍스트 색상" FontWeight="SemiBold" />
              <TextBlock Text="중립 일정 칩에서 읽기 쉬운 색상만 저장할 수 있습니다."
                         Classes="caption" />
              <WrapPanel Orientation="Horizontal">
                <Button Tag="#141A24" Background="#141A24" Width="36"
                        MinWidth="36" Height="36" MinHeight="36" Padding="0"
                        Margin="0,0,8,0" ToolTip.Tip="차콜"
                        AutomationProperties.Name="차콜 텍스트 색상"
                        Click="PaletteColor_OnClick" />
                <Button Tag="#354153" Background="#354153" Width="36"
                        MinWidth="36" Height="36" MinHeight="36" Padding="0"
                        Margin="0,0,8,0" ToolTip.Tip="슬레이트"
                        AutomationProperties.Name="슬레이트 텍스트 색상"
                        Click="PaletteColor_OnClick" />
                <Button Tag="#0041E6" Background="#0041E6" Width="36"
                        MinWidth="36" Height="36" MinHeight="36" Padding="0"
                        Margin="0,0,8,0" ToolTip.Tip="쏘카 블루"
                        AutomationProperties.Name="쏘카 블루 텍스트 색상"
                        Click="PaletteColor_OnClick" />
                <Button Tag="#0A1491" Background="#0A1491" Width="36"
                        MinWidth="36" Height="36" MinHeight="36" Padding="0"
                        Margin="0,0,8,0" ToolTip.Tip="네이비"
                        AutomationProperties.Name="네이비 텍스트 색상"
                        Click="PaletteColor_OnClick" />
                <Button Tag="#7A2432" Background="#7A2432" Width="36"
                        MinWidth="36" Height="36" MinHeight="36" Padding="0"
                        Margin="0,0,8,0" ToolTip.Tip="버건디"
                        AutomationProperties.Name="버건디 텍스트 색상"
                        Click="PaletteColor_OnClick" />
                <Button Tag="#2F6B3C" Background="#2F6B3C" Width="36"
                        MinWidth="36" Height="36" MinHeight="36" Padding="0"
                        ToolTip.Tip="포레스트"
                        AutomationProperties.Name="포레스트 텍스트 색상"
                        Click="PaletteColor_OnClick" />
              </WrapPanel>
              <TextBox Text="{Binding Draft.Color, Mode=TwoWay,
                                      UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="#RRGGBB" MaxLength="7" />
              <TextBlock Text="{Binding Draft.ContrastText}" Classes="caption" />
            </StackPanel>

            <Border Padding="12" Background="#F8F9FC"
                    BorderBrush="{DynamicResource SocarBorderBrush}"
                    BorderThickness="1" CornerRadius="8">
              <Grid ColumnDefinitions="64,*">
                <TextBlock Text="{Binding Draft.PreviewTime}" FontSize="12"
                           Classes="schedule-time" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding Draft.PreviewTitle}"
                           Foreground="{Binding Draft.PreviewBrush}"
                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
              </Grid>
            </Border>

            <TextBlock Text="{Binding Draft.ValidationMessage}"
                       IsVisible="{Binding Draft.HasValidationError}"
                       Classes="status-warning" TextWrapping="Wrap" />

            <Grid ColumnDefinitions="*,Auto,8,Auto">
              <TextBlock Text="저장되지 않은 변경이 있습니다."
                         IsVisible="{Binding Draft.HasUnsavedChanges}"
                         Classes="caption" VerticalAlignment="Center" />
              <Button Grid.Column="1" Content="취소" Classes="ghost"
                      Click="Cancel_OnClick" />
              <Button Grid.Column="3" Content="{Binding Draft.SaveButtonText}"
                      Classes="primary" IsEnabled="{Binding Draft.CanSave}"
                      Click="Save_OnClick" />
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}"
               Classes="status-warning" Margin="0,12,0,0"
               TextWrapping="Wrap" />
  </Grid>
</Window>
