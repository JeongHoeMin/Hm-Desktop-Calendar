<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HmDesktopCalendar.App"
             xmlns:local="using:HmDesktopCalendar"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://HmDesktopCalendar/Themes/SocarFrame.axaml" />
    </Application.Styles>
</Application>
