<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <!-- 쏘카 공식 브랜드 팔레트 -->
    <Color x:Key="SocarBlue01">#EBF5FF</Color>
    <Color x:Key="SocarBlue02">#D6EBFF</Color>
    <Color x:Key="SocarBlue03">#A3D1FF</Color>
    <Color x:Key="SocarBlue04">#66B0FF</Color>
    <Color x:Key="SocarBlue05">#3393FF</Color>
    <Color x:Key="SocarBlue06">#0078FF</Color>
    <Color x:Key="SocarBlue07">#005AFF</Color>
    <Color x:Key="SocarBlue08">#0041E6</Color>
    <Color x:Key="SocarBlue09">#0A1491</Color>
    <Color x:Key="SocarBlue10">#050A5A</Color>
    <Color x:Key="SocarGray01">#F2F3F8</Color>
    <Color x:Key="SocarGray02">#E5E8EF</Color>
    <Color x:Key="SocarGray03">#CBD1DC</Color>
    <Color x:Key="SocarGray04">#B4BBCB</Color>
    <Color x:Key="SocarGray05">#99A1B1</Color>
    <Color x:Key="SocarGray06">#697383</Color>
    <Color x:Key="SocarGray07">#4A5667</Color>
    <Color x:Key="SocarGray08">#354153</Color>
    <Color x:Key="SocarGray09">#262F3C</Color>
    <Color x:Key="SocarGray10">#141A24</Color>
    <Color x:Key="SocarStatus">#FF5065</Color>

    <!-- 화면은 의미 토큰만 참조한다. -->
    <SolidColorBrush x:Key="SocarPrimaryBrush" Color="{StaticResource SocarBlue06}" />
    <SolidColorBrush x:Key="SocarPrimaryHoverBrush" Color="{StaticResource SocarBlue07}" />
    <SolidColorBrush x:Key="SocarPrimaryPressedBrush" Color="{StaticResource SocarBlue08}" />
    <SolidColorBrush x:Key="SocarPrimarySoftBrush" Color="{StaticResource SocarBlue01}" />
    <SolidColorBrush x:Key="SocarPrimarySoftHoverBrush" Color="{StaticResource SocarBlue02}" />
    <SolidColorBrush x:Key="SocarSurfaceBrush" Color="White" />
    <SolidColorBrush x:Key="SocarSurfaceSubtleBrush" Color="#F8F9FC" />
    <SolidColorBrush x:Key="SocarSurfaceMutedBrush" Color="{StaticResource SocarGray01}" />
    <SolidColorBrush x:Key="SocarCalendarSurfaceBrush" Color="#F7F9FC" Opacity="0.95" />
    <SolidColorBrush x:Key="SocarCalendarCellBrush" Color="White" Opacity="0.82" />
    <SolidColorBrush x:Key="SocarTextPrimaryBrush" Color="{StaticResource SocarGray10}" />
    <SolidColorBrush x:Key="SocarTextSecondaryBrush" Color="{StaticResource SocarGray07}" />
    <SolidColorBrush x:Key="SocarTextMutedBrush" Color="{StaticResource SocarGray06}" />
    <SolidColorBrush x:Key="SocarTextInverseBrush" Color="White" />
    <SolidColorBrush x:Key="SocarBorderBrush" Color="{StaticResource SocarGray02}" />
    <SolidColorBrush x:Key="SocarBorderStrongBrush" Color="{StaticResource SocarGray03}" />
    <SolidColorBrush x:Key="SocarDisabledSurfaceBrush" Color="{StaticResource SocarGray01}" />
    <SolidColorBrush x:Key="SocarDisabledTextBrush" Color="{StaticResource SocarGray05}" />
    <SolidColorBrush x:Key="SocarDangerBrush" Color="{StaticResource SocarStatus}" />
    <SolidColorBrush x:Key="SocarSundayBrush" Color="{StaticResource SocarStatus}" />
    <SolidColorBrush x:Key="SocarSaturdayBrush" Color="{StaticResource SocarBlue07}" />
    <SolidColorBrush x:Key="SocarScheduleTimeBrush" Color="{StaticResource SocarBlue08}" />
    <SolidColorBrush x:Key="SocarMoveBarBrush" Color="{StaticResource SocarGray08}" Opacity="0.92" />
    <SolidColorBrush x:Key="SocarResizeHitBrush" Color="Black" Opacity="0.004" />
    <SolidColorBrush x:Key="SocarResizeHandleBrush" Color="{StaticResource SocarGray09}" Opacity="0.45" />
    <FontFamily x:Key="SocarFontFamily">avares://HmDesktopCalendar/Assets/Fonts#Pretendard Variable</FontFamily>

    <!-- 4pt 간격 체계와 공통 모서리 -->
    <Thickness x:Key="SocarSpace1">4</Thickness>
    <Thickness x:Key="SocarSpace2">8</Thickness>
    <Thickness x:Key="SocarSpace3">12</Thickness>
    <Thickness x:Key="SocarSpace4">16</Thickness>
    <Thickness x:Key="SocarSpace6">24</Thickness>
    <Thickness x:Key="SocarSpace8">32</Thickness>
    <CornerRadius x:Key="SocarRadiusSmall">8</CornerRadius>
    <CornerRadius x:Key="SocarRadiusMedium">12</CornerRadius>
    <CornerRadius x:Key="SocarRadiusLarge">16</CornerRadius>
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="FontFamily" Value="{DynamicResource SocarFontFamily}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource SocarTextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource SocarSurfaceBrush}" />
  </Style>

  <Style Selector="Window.dialog">
    <Setter Property="Background" Value="{DynamicResource SocarSurfaceSubtleBrush}" />
  </Style>

  <Style Selector="TextBlock.display">
    <Setter Property="FontSize" Value="28" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="LineHeight" Value="36" />
  </Style>

  <Style Selector="TextBlock.title">
    <Setter Property="FontSize" Value="20" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="28" />
  </Style>

  <Style Selector="TextBlock.body">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="LineHeight" Value="22" />
  </Style>

  <Style Selector="TextBlock.caption">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="LineHeight" Value="16" />
    <Setter Property="Foreground" Value="{DynamicResource SocarTextSecondaryBrush}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="16,0" />
    <Setter Property="CornerRadius" Value="{DynamicResource SocarRadiusSmall}" />
    <Setter Property="Background" Value="{DynamicResource SocarSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarBorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource SocarTextPrimaryBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{DynamicResource SocarSurfaceMutedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarGray04}" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="{DynamicResource SocarGray02}" />
  </Style>

  <Style Selector="Button:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource SocarPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <Style Selector="Button:disabled">
    <Setter Property="Background" Value="{DynamicResource SocarDisabledSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SocarDisabledTextBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource SocarPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarPrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SocarTextInverseBrush}" />
  </Style>

  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="{DynamicResource SocarPrimaryHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarPrimaryHoverBrush}" />
  </Style>

  <Style Selector="Button.primary:pressed">
    <Setter Property="Background" Value="{DynamicResource SocarPrimaryPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarPrimaryPressedBrush}" />
  </Style>

  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="{DynamicResource SocarPrimarySoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarPrimarySoftBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SocarPrimaryPressedBrush}" />
  </Style>

  <Style Selector="Button.secondary:pointerover">
    <Setter Property="Background" Value="{DynamicResource SocarPrimarySoftHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarPrimarySoftHoverBrush}" />
  </Style>

  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource SocarTextSecondaryBrush}" />
  </Style>

  <Style Selector="Button.ghost:pointerover">
    <Setter Property="Background" Value="{DynamicResource SocarSurfaceMutedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarSurfaceMutedBrush}" />
  </Style>

  <Style Selector="Button.icon">
    <Setter Property="MinWidth" Value="40" />
    <Setter Property="Width" Value="40" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="FontSize" Value="17" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="MinHeight" Value="44" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="CornerRadius" Value="{DynamicResource SocarRadiusSmall}" />
    <Setter Property="Background" Value="{DynamicResource SocarSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarBorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource SocarTextPrimaryBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource SocarPrimaryBrush}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource SocarBlue03}" />
  </Style>

  <Style Selector="TextBox:focus-within">
    <Setter Property="BorderBrush" Value="{DynamicResource SocarPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <Style Selector="TextBox:disabled">
    <Setter Property="Background" Value="{DynamicResource SocarDisabledSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SocarDisabledTextBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="MinHeight" Value="44" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="CornerRadius" Value="{DynamicResource SocarRadiusSmall}" />
    <Setter Property="Background" Value="{DynamicResource SocarSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarBorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource SocarTextPrimaryBrush}" />
  </Style>

  <Style Selector="ComboBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource SocarPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <Style Selector="ComboBox:disabled">
    <Setter Property="Background" Value="{DynamicResource SocarDisabledSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SocarDisabledTextBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="FlyoutPresenter">
    <Setter Property="Padding" Value="8" />
    <Setter Property="CornerRadius" Value="{DynamicResource SocarRadiusMedium}" />
    <Setter Property="Background" Value="{DynamicResource SocarSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="MenuFlyoutPresenter">
    <Setter Property="Padding" Value="8" />
    <Setter Property="CornerRadius" Value="{DynamicResource SocarRadiusMedium}" />
    <Setter Property="Background" Value="{DynamicResource SocarSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Padding" Value="24" />
    <Setter Property="CornerRadius" Value="{DynamicResource SocarRadiusLarge}" />
    <Setter Property="Background" Value="{DynamicResource SocarSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Border.calendar-shell">
    <Setter Property="Background" Value="{DynamicResource SocarCalendarSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarBorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource SocarRadiusLarge}" />
  </Style>

  <Style Selector="Border.date-cell">
    <Setter Property="Background" Value="{DynamicResource SocarCalendarCellBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SocarBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource SocarRadiusSmall}" />
  </Style>

  <Style Selector="TextBlock.weekday">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource SocarTextSecondaryBrush}" />
  </Style>

  <Style Selector="TextBlock.sunday">
    <Setter Property="Foreground" Value="{DynamicResource SocarSundayBrush}" />
  </Style>

  <Style Selector="TextBlock.saturday">
    <Setter Property="Foreground" Value="{DynamicResource SocarSaturdayBrush}" />
  </Style>

  <Style Selector="TextBlock.status-warning">
    <Setter Property="Foreground" Value="{DynamicResource SocarDangerBrush}" />
  </Style>

  <Style Selector="TextBlock.schedule-time">
    <Setter Property="Foreground" Value="{DynamicResource SocarScheduleTimeBrush}" />
  </Style>

  <Style Selector="TextBlock.schedule-more">
    <Setter Property="Foreground" Value="{DynamicResource SocarTextMutedBrush}" />
  </Style>
</Styles>
