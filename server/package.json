{
  "name": "hm-desktop-calendar-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node -e \"const f=require('fs');f.mkdirSync('dist/database',{recursive:true});for(const x of f.readdirSync('src/database').filter(x=>x.endsWith('.sql')))f.copyFileSync('src/database/'+x,'dist/database/'+x)\"",
    "start": "node dist/index.js",
    "migrate": "tsx src/database/migrate.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/websocket": "^11.2.0",
    "@sinclair/typebox": "^0.34.41",
    "argon2": "^0.44.0",
    "dotenv": "^17.2.0",
    "fastify": "^5.6.0",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.16.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "@types/ws": "^8.18.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0",
    "yaml": "^2.9.0"
  }
}
