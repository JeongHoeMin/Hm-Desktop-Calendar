POSTGRES_DB=calendar
POSTGRES_USER=calendar
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
DATABASE_URL=postgresql://calendar:replace-with-a-long-random-database-password@db:5432/calendar
DATABASE_SSL=false
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
TOKEN_HASH_SECRET=replace-with-another-32-random-characters
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
BODY_LIMIT_BYTES=262144
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
CORS_ALLOWED_ORIGINS=
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
